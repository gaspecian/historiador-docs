# --- Rust ---
target/
**/*.rs.bk
Cargo.lock.bak
# proptest shrinks counterexamples to this file on failure; regenerated
# each run and not worth versioning.
**/*.proptest-regressions

# --- Node ---
node_modules/
.pnpm-store/
.next/
out/
dist/
.turbo/
*.tsbuildinfo

# --- Environment ---
.env
.env.local
.env.*.local

# --- Editor / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Coverage ---
coverage/
*.lcov
lcov.info

# --- Runtime ---
*.pid
*.log

# --- Vendored upstream dependencies (populated by scripts/setup-vexfs.sh) ---
vendor/

# Note: openapi.yaml and packages/types/generated/** are committed intentionally
# so contributors can see the API contract without running the full build.
