# Copy to .env before running `docker compose up`. Do NOT commit .env.
#
# The three Postgres passwords below are baked into docker-compose.yml
# defaults for local dev. Override in production.

# --- Postgres ---
POSTGRES_ADMIN_PASSWORD=devpassword
POSTGRES_API_PASSWORD=apipass
POSTGRES_MCP_PASSWORD=mcppass

# --- Rust logging ---
# Default: everything at info+, sqlx query chatter quieted to warn. Note that
# bin-level tracing targets are `api` and `mcp` (from the binary names) while
# library modules use `historiador_api::*` and `historiador_db::*`. Keep the
# default broad enough to catch both; override individual targets when
# debugging, e.g. RUST_LOG=debug,sqlx=warn.
RUST_LOG=info,sqlx=warn

# --- Build metadata (populated by CI; "unknown" locally is fine) ---
GIT_SHA=unknown

# --- Host port bindings ---
# Override these if the defaults collide with something else on your host.
# Container-internal ports are fixed; only the host-side mapping changes.
HOST_PORT_WEB=3000
HOST_PORT_API=3001
HOST_PORT_MCP=3002
HOST_PORT_POSTGRES=5432
HOST_PORT_VEXFS=7680
