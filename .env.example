# Configuracao local para Historiador Doc.
# Copie para .env antes de rodar. NUNCA commite o .env.
#
# O docker-compose roda apenas infra (postgres + ollama). A API, o MCP
# e o frontend rodam na maquina host. As variaveis abaixo sao lidas
# tanto pelo compose (postgres/ollama) quanto pelos binarios Rust
# (via dotenvy) e pelo Next.js (NEXT_PUBLIC_*).

# --- Postgres (compose + binarios host) ---
POSTGRES_ADMIN_PASSWORD=devpassword
POSTGRES_API_PASSWORD=apipass
POSTGRES_MCP_PASSWORD=mcppass

# Conexoes de host → postgres no localhost. Porta padrao 5432 (compose).
DATABASE_URL_READWRITE=postgres://historiador_api:apipass@localhost:5432/historiador
DATABASE_URL_READONLY=postgres://historiador_mcp:mcppass@localhost:5432/historiador

# --- Ollama ---
OLLAMA_MODEL=llama3.2:1b

# --- Rust logging ---
RUST_LOG=info,sqlx=warn

# --- Build metadata (CI popula; "unknown" localmente e ok) ---
GIT_SHA=unknown

# --- Auth & encryption (Sprint 2) ---
# JWT_SECRET assina access tokens HS256 (minimo 32 chars).
# APP_ENCRYPTION_KEY encripta a chave LLM no Postgres (base64 de 32 bytes).
# DEFAULTS DE DEV — em producao, gere com: openssl rand -base64 32
JWT_SECRET=dev-jwt-secret-do-not-use-in-production-xxxxxx
APP_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# URL publica usada nos activation_url de POST /admin/users/invite.
PUBLIC_BASE_URL=http://localhost:3000

# --- Next.js API proxy (server-side rewrite in next.config.ts) ---
# Local dev points at localhost; Docker overrides to http://api:3001.
API_INTERNAL_URL=http://localhost:3001

# --- AI editor v2 (Sprint 11) ---
# Master feature flag. OFF by default. When true, exposes /editor/ws
# WebSocket, block-op tool calls, proposal overlay, autonomy modes.
# Flip after tier-A phases verify in staging. The legacy SSE editor
# (Sprint 4) is deleted at flip time per ADR-009.
EDITOR_V2_ENABLED=false
# The frontend reads this mirror; set alongside the server flag.
NEXT_PUBLIC_EDITOR_V2=false
# System prompt file inside PROMPT_DIR (default "prompts/agent").
# Ship a new version by adding prompts/agent/v2.md and bumping here.
PROMPT_VERSION=v1
# PROMPT_DIR=prompts/agent  # override for non-repo-root layouts

# --- LLM providers (Sprint 4) ---
# Set LLM_PROVIDER to "openai" or "anthropic" and provide LLM_API_KEY
# to use real LLM providers. Leave unset to use stubs (safe for dev).
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# EMBEDDING_API_KEY=sk-...  # separate key for embeddings when provider is anthropic

# --- MCP bearer token (Sprint 4) ---
# Static token for MCP endpoint auth. Defaults to "dev-mcp-token" if unset.
# MCP_BEARER_TOKEN=your-secret-token

# --- Chronik-Stream (ADR-007) ---
# Kafka-compatible broker for event streaming + vector/full-text search.
CHRONIK_KAFKA_BROKER=localhost:9092
# DataFusion SQL REST API for analytics queries.
CHRONIK_SQL_URL=http://localhost:6092
# Search API endpoint (vector + full-text via Chronik).
CHRONIK_SEARCH_URL=http://localhost:6092

# Dev-only: allow the api/mcp binaries to fall back to the in-memory
# vector store when Chronik is unreachable. Defaults to false (production
# behavior: bail at boot). The in-memory store loses all chunks on every
# process restart, which silently breaks page version history — never
# enable this in production. docker-compose.prod.yml sets this to false.
ALLOW_IN_MEMORY_VECTOR_STORE=true

# --- Host port bindings (compose) ---
# Altere se as portas padrao colidirem com outro servico na sua maquina.
HOST_PORT_POSTGRES=5432
HOST_PORT_OLLAMA=11434
HOST_PORT_CHRONIK_KAFKA=9092
HOST_PORT_CHRONIK_SQL=6092
