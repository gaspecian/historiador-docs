{
  "name": "historiador-doc",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "turbo run build",
    "build:rust": "cargo build --release --workspace",
    "build:types": "openapi-typescript openapi.yaml -o packages/types/generated/index.ts",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:rust": "cargo fmt --check && cargo clippy --all-targets --all-features -- -D warnings",
    "test": "turbo run test",
    "test:rust": "cargo test --workspace",
    "gen:openapi": "cargo run --release -p historiador_api --bin gen-openapi",
    "gen:types": "pnpm gen:openapi && pnpm build:types"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.6.0"
  }
}
